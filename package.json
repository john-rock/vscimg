{
  "name": "image-optimizer",
  "displayName": "Image Optimizer",
  "description": "Right-click any image or folder in the Explorer to compress it in place — TinyPNG-style lossy optimization, fully local.",
  "version": "0.3.2",
  "publisher": "johnrock",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "imageOptimizer.optimize",
        "title": "Optimize Image",
        "category": "Image Optimizer"
      },
      {
        "command": "imageOptimizer.preview",
        "title": "Preview & Optimize Image…",
        "category": "Image Optimizer"
      },
      {
        "command": "imageOptimizer.optimizeAs",
        "title": "Optimize Image As…",
        "category": "Image Optimizer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "imageOptimizer.optimize",
          "when": "explorerResourceIsFolder || resourceExtname =~ /\\.(png|jpe?g|webp|avif|tiff?|gif)$/i",
          "group": "7_modification@1"
        },
        {
          "command": "imageOptimizer.preview",
          "when": "!explorerResourceIsFolder && resourceExtname =~ /\\.(png|jpe?g|webp|avif|gif)$/i",
          "group": "7_modification@2"
        },
        {
          "command": "imageOptimizer.optimizeAs",
          "when": "!explorerResourceIsFolder && resourceExtname =~ /\\.(png|jpe?g|webp|avif|tiff?|gif)$/i",
          "group": "7_modification@3"
        }
      ]
    },
    "configuration": {
      "title": "Image Optimizer",
      "properties": {
        "imageOptimizer.jpegQuality": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "JPEG quality (1–100). Lower means smaller files."
        },
        "imageOptimizer.pngQuality": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "PNG quality target for palette quantization (1–100)."
        },
        "imageOptimizer.webpQuality": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "WebP / AVIF quality (1–100)."
        },
        "imageOptimizer.skipIfLargerOrEqual": {
          "type": "boolean",
          "default": true,
          "description": "When overwriting in place, keep the original if optimization does not reduce file size."
        },
        "imageOptimizer.minSavingsPercent": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 100,
          "description": "When overwriting in place, only write the result if it saves at least this percent."
        },
        "imageOptimizer.notificationSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "How long the result notification stays on screen before auto-hiding."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "npm run build && vsce package",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
